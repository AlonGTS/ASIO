{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "tracker-so: live",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tracker-so.py",
            "args": ["--mode", "live"],
            "console": "integratedTerminal"
        },
        {
            "name": "tracker-so: playback",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/tracker-so.py",
            "args": ["--mode", "playback", "--loop"],
            "console": "integratedTerminal"
        },
        {
            "name": "GCS: UI only (no Pi)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/gcs.py",
            "args": ["--pi", "127.0.0.1"],
            "console": "integratedTerminal"
        },
        {
            "name": "GCS: local webcam test",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/gcs.py",
            "args": ["--pi", "127.0.0.1", "--test"],
            "console": "integratedTerminal"
        },
        {
            "name": "GCS: connect to Pi",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/gcs.py",
            "args": ["--pi", "${input:piIp}"],
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "piIp",
            "type": "promptString",
            "description": "Pi IP address",
            "default": "192.168.1.100"
        }
    ]
}
